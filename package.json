{
  "name": "helmsman",
  "version": "1.0.0",
  "description": "Chrome extension to monitor and control Klipper/Moonraker (and future) 3D printers",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "client:build": "pnpm --dir modules/moonraker-client run build",
    "client:test": "pnpm --dir modules/moonraker-client test"
  },
  "keywords": [
    "3d-printing",
    "klipper",
    "moonraker",
    "chrome-extension"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@jhyland87/moonraker-client": "file:./modules/moonraker-client",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "events": "^3.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/chrome": "^0.1.43",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-bundle-analyzer": "^1.3.8"
  }
}
