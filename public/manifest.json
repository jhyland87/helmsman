{
  "manifest_version": 3,
  "name": "Helmsman",
  "version": "1.0.0",
  "description": "Monitor and control Klipper/Moonraker (and future) 3D printers from your browser.",
  "minimum_chrome_version": "116",
  "action": {
    "default_popup": "index.html",
    "default_title": "Helmsman",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "alarms", "downloads", "tabs"],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
